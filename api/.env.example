# =============================================================================
# Stash Sense — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Stash instance (required)
STASH_URL=http://localhost:9999
STASH_API_KEY=your-stash-api-key

# Local Stash Rate Limit (requests per second)
# Controls how fast the sidecar queries your local Stash during analysis
# Default: 5.0 req/sec (safe for most systems)
# STASH_RATE_LIMIT=5.0

# =============================================================================
# Docker-set variables (set automatically in the container)
# Override these only when running outside Docker
# =============================================================================

# DATA_DIR — Where the sidecar stores databases and working files
# Default in Docker: /data (mapped via volume mount)
# For local dev: ./data or an absolute path
# DATA_DIR=/data

# PYTHONUNBUFFERED — Forces unbuffered stdout/stderr for real-time log output
# Default in Docker: 1
# PYTHONUNBUFFERED=1

# ENABLE_TATTOO_SIGNAL — Tattoo detection signal for duplicate matching
# "auto" enables if ONNX model is available, "off" disables
# Default in Docker: auto
# ENABLE_TATTOO_SIGNAL=auto

# =============================================================================
# Stash-Box Endpoints (for upstream sync and database building)
# API keys are auto-discovered from Stash's configured metadata providers,
# but can be set here to override or for standalone sidecar use.
# =============================================================================

# StashDB - Primary stash-box (~100k+ performers)
STASHDB_URL=https://stashdb.org/graphql
STASHDB_API_KEY=your-stashdb-api-key

# ThePornDB
THEPORNDB_URL=https://theporndb.net/graphql
THEPORNDB_API_KEY=your-theporndb-api-key

# PMVStash - PMV-focused stash-box (~6.5k performers)
PMVSTASH_URL=https://pmvstash.org/graphql
PMVSTASH_API_KEY=your-pmvstash-api-key

# JAVStash - JAV-focused stash-box (~21k performers)
JAVSTASH_URL=https://javstash.org/graphql
JAVSTASH_API_KEY=your-javstash-api-key

# FansDB - OnlyFans-focused stash-box
FANSDB_URL=https://fansdb.cc/graphql
FANSDB_API_KEY=your-fansdb-api-key

# =============================================================================
# Per-endpoint rate limits (seconds between requests)
# Default: 0.25s = 240 requests/min (safe for all endpoints)
# =============================================================================
# STASHDB_RATE_LIMIT=0.25
# THEPORNDB_RATE_LIMIT=0.25
# PMVSTASH_RATE_LIMIT=0.25
# JAVSTASH_RATE_LIMIT=0.25
